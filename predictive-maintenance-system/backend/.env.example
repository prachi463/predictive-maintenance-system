# Copy this file to .env and fill in real values.

# MongoDB Atlas connection string. Leave blank to use local SQLite fallback.
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority
MONGO_DB_NAME=predictive_maintenance

# Failure-risk probability threshold that triggers an alert (0 - 1)
ALERT_THRESHOLD=0.7

# Port the Flask/Socket.IO server listens on
PORT=5000
